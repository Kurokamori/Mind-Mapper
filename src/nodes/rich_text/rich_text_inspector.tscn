custom_minimum_size = Vector2(0, 160)
layout_mode = 2
wrap_mode = 1

[node name="FontSizeRow" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="FontSizeLabel" type="Label" parent="FontSizeRow"]
layout_mode = 2
size_flags_horizontal = 3
