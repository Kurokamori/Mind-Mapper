[ext_resource type="PackedScene" path="res://src/nodes/rich_text/bbcode_toolbar.tscn" id="2_bbtb"]

[node name="RichTextInspector" type="VBoxContainer"]
script = ExtResource("1_rti")
theme_override_constants/separation = 6

[node name="Header" type="Label" parent="."]
layout_mode = 2
text = "Rich Text"

[node name="HelpLabel" type="Label" parent="."]
layout_mode = 2
text = "Use the toolbar to wrap the selection. Manual BBCode is supported below."
