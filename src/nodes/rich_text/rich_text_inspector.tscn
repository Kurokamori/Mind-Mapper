[node name="FormatToolbarScroll" type="ScrollContainer" parent="."]
layout_mode = 2
horizontal_scroll_mode = 2
vertical_scroll_mode = 0

[node name="FormatToolbar" parent="FormatToolbarScroll" instance=ExtResource("2_bbtb")]
unique_name_in_owner = true
layout_mode = 2

[node name="BBEdit" type="TextEdit" parent="."]
