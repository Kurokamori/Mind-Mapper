[node name="LabelEdit" type="LineEdit" parent="LabelSection"]
unique_name_in_owner = true
layout_mode = 2

[node name="VolumeSection" type="VBoxContainer" parent="."]
layout_mode = 2

[node name="VolumeRow" type="HBoxContainer" parent="VolumeSection"]
layout_mode = 2

[node name="VolumeLabel" type="Label" parent="VolumeSection/VolumeRow"]
layout_mode = 2
size_flags_horizontal = 3
