[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/nodes/sound/sound_inspector.gd" id="1_si"]

[node name="SoundInspector" type="VBoxContainer"]
script = ExtResource("1_si")
theme_override_constants/separation = 8

[node name="Header" type="Label" parent="."]
layout_mode = 2
theme_type_variation = &"InspectorTitleLabel"
text = "Sound"

[node name="Surface" type="PanelContainer" parent="."]
layout_mode = 2
theme_type_variation = &"InspectorSectionPanel"

[node name="Body" type="VBoxContainer" parent="Surface"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="SourceHeader" type="Label" parent="Surface/Body"]
layout_mode = 2
theme_type_variation = &"InspectorSubsectionLabel"
text = "SOURCE"

[node name="PathLabel" type="Label" parent="Surface/Body"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"InspectorValueLabel"
autowrap_mode = 2

[node name="ReplaceButton" type="Button" parent="Surface/Body"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"GhostButton"
text = "Replace audio…"

[node name="LabelSection" type="VBoxContainer" parent="Surface/Body"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="LabelLabel" type="Label" parent="Surface/Body/LabelSection"]
layout_mode = 2
theme_type_variation = &"InspectorSubsectionLabel"
text = "DISPLAY LABEL"

[node name="LabelEdit" type="LineEdit" parent="Surface/Body/LabelSection"]
unique_name_in_owner = true
layout_mode = 2

[node name="VolumeSection" type="VBoxContainer" parent="Surface/Body"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="VolumeRow" type="HBoxContainer" parent="Surface/Body/VolumeSection"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="VolumeLabel" type="Label" parent="Surface/Body/VolumeSection/VolumeRow"]
layout_mode = 2
size_flags_horizontal = 3
theme_type_variation = &"InspectorSubsectionLabel"
text = "VOLUME"

[node name="VolumeValue" type="Label" parent="Surface/Body/VolumeSection/VolumeRow"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"InspectorValueLabel"
text = "+0.0 dB"

[node name="VolumeSlider" type="HSlider" parent="Surface/Body/VolumeSection"]
unique_name_in_owner = true
layout_mode = 2
min_value = -40.0
max_value = 12.0
step = 0.1

[node name="FileDialog" type="FileDialog" parent="."]
unique_name_in_owner = true
title = "Choose audio"
size = Vector2i(800, 600)
ok_button_text = "Open"
file_mode = 0
access = 2
filters = PackedStringArray("*.mp3 ; MP3", "*.ogg ; Ogg Vorbis", "*.wav ; WAV")

[node name="EmbedChoice" type="ConfirmationDialog" parent="."]
unique_name_in_owner = true
title = "Add Sound"
size = Vector2i(420, 120)
ok_button_text = "Embed"
dialog_text = "Embed the audio into this project (copies the file) or link to its current location?"
