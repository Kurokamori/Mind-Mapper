[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/nodes/pinboard/pinboard_inspector.gd" id="1_pini"]

[node name="PinboardInspector" type="VBoxContainer"]
script = ExtResource("1_pini")
theme_override_constants/separation = 8

[node name="Header" type="Label" parent="."]
layout_mode = 2
theme_type_variation = &"InspectorTitleLabel"
text = "Pinboard"

[node name="Surface" type="PanelContainer" parent="."]
layout_mode = 2
theme_type_variation = &"InspectorSectionPanel"

[node name="Body" type="VBoxContainer" parent="Surface"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="TitleSection" type="VBoxContainer" parent="Surface/Body"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="TitleLabel" type="Label" parent="Surface/Body/TitleSection"]
layout_mode = 2
theme_type_variation = &"InspectorSubsectionLabel"
text = "TITLE"

[node name="TitleEdit" type="LineEdit" parent="Surface/Body/TitleSection"]
unique_name_in_owner = true
layout_mode = 2

[node name="RetargetSection" type="VBoxContainer" parent="Surface/Body"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="RetargetLabel" type="Label" parent="Surface/Body/RetargetSection"]
layout_mode = 2
theme_type_variation = &"InspectorSubsectionLabel"
text = "TARGET BOARD"

[node name="RetargetOption" type="OptionButton" parent="Surface/Body/RetargetSection"]
unique_name_in_owner = true
layout_mode = 2

[node name="ButtonsRow" type="HBoxContainer" parent="Surface/Body"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="OpenButton" type="Button" parent="Surface/Body/ButtonsRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_type_variation = &"AccentButton"
text = "Open pinboard"

[node name="RefreshButton" type="Button" parent="Surface/Body/ButtonsRow"]
unique_name_in_owner = true
custom_minimum_size = Vector2(40, 0)
layout_mode = 2
theme_type_variation = &"GhostButton"
text = "↻"
tooltip_text = "Refresh preview"
