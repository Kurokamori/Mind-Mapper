[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/nodes/subpage/subpage_inspector.gd" id="1_subi"]

[node name="SubpageInspector" type="VBoxContainer"]
script = ExtResource("1_subi")
theme_override_constants/separation = 6

[node name="Header" type="Label" parent="."]
layout_mode = 2
text = "Subpage"
theme_override_font_sizes/font_size = 16

[node name="TitleSection" type="VBoxContainer" parent="."]
layout_mode = 2

[node name="TitleLabel" type="Label" parent="TitleSection"]
layout_mode = 2
text = "Title"

[node name="TitleEdit" type="LineEdit" parent="TitleSection"]
unique_name_in_owner = true
layout_mode = 2

[node name="RetargetSection" type="VBoxContainer" parent="."]
layout_mode = 2

[node name="RetargetLabel" type="Label" parent="RetargetSection"]
layout_mode = 2
text = "Target board"

[node name="RetargetOption" type="OptionButton" parent="RetargetSection"]
unique_name_in_owner = true
layout_mode = 2

[node name="ZoomRow" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="ZoomLabel" type="Label" parent="ZoomRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Zoom %"

[node name="ZoomSpin" type="SpinBox" parent="ZoomRow"]
unique_name_in_owner = true
layout_mode = 2
min_value = 5.0
max_value = 400.0
step = 5.0
value = 50.0

[node name="AutoFitCheck" type="CheckBox" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Auto-fit content"

[node name="ButtonsRow" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="OpenButton" type="Button" parent="ButtonsRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "Open subpage"

[node name="RefreshButton" type="Button" parent="ButtonsRow"]
unique_name_in_owner = true
layout_mode = 2
text = "↻"
