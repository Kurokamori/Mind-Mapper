[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/editor/link_section.gd" id="1_ls"]

[node name="LinkSection" type="VBoxContainer"]
script = ExtResource("1_ls")
theme_override_constants/separation = 4

[node name="HSep" type="HSeparator" parent="."]
layout_mode = 2

[node name="Header" type="Label" parent="."]
layout_mode = 2
text = "Link"
theme_override_font_sizes/font_size = 14

[node name="StatusLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
autowrap_mode = 2
text = "No link"
theme_override_font_sizes/font_size = 11

[node name="ButtonsRow" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="SetButton" type="Button" parent="ButtonsRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "Set link…"

[node name="FollowButton" type="Button" parent="ButtonsRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Follow"

[node name="ClearButton" type="Button" parent="ButtonsRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Clear"

[node name="Hint" type="Label" parent="."]
layout_mode = 2
autowrap_mode = 2
text = "Tip: Ctrl+click an item with a link to follow it."
theme_override_font_sizes/font_size = 10
