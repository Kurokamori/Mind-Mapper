[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/editor/minimap.gd" id="1_mm"]

[node name="Minimap" type="PanelContainer"]
custom_minimum_size = Vector2(220, 160)
mouse_filter = 1
theme_type_variation = &"MinimapPanel"
script = ExtResource("1_mm")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 6
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 6

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="Header" type="HBoxContainer" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
mouse_filter = 0
mouse_default_cursor_shape = 13
tooltip_text = "Drag to move"

[node name="Title" type="Label" parent="Margin/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
mouse_filter = 2
theme_type_variation = &"SectionHeader"
text = "MINIMAP"

[node name="CloseButton" type="Button" parent="Margin/VBox/Header"]
unique_name_in_owner = true
custom_minimum_size = Vector2(22, 22)
layout_mode = 2
focus_mode = 0
theme_type_variation = &"CloseIconButton"
tooltip_text = "Close minimap"
text = "✕"

[node name="ZoomBar" type="HBoxContainer" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 4

[node name="ZoomOutButton" type="Button" parent="Margin/VBox/ZoomBar"]
unique_name_in_owner = true
custom_minimum_size = Vector2(28, 22)
layout_mode = 2
focus_mode = 0
theme_type_variation = &"FlatButton"
text = "−"
tooltip_text = "Zoom out"

[node name="ZoomLabel" type="Label" parent="Margin/VBox/ZoomBar"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_type_variation = &"MutedLabel"
text = "100%"
horizontal_alignment = 1

[node name="ZoomInButton" type="Button" parent="Margin/VBox/ZoomBar"]
unique_name_in_owner = true
custom_minimum_size = Vector2(28, 22)
layout_mode = 2
focus_mode = 0
theme_type_variation = &"FlatButton"
text = "+"
tooltip_text = "Zoom in"

[node name="ZoomFitButton" type="Button" parent="Margin/VBox/ZoomBar"]
unique_name_in_owner = true
custom_minimum_size = Vector2(40, 22)
layout_mode = 2
focus_mode = 0
theme_type_variation = &"FlatButton"
text = "Fit"
tooltip_text = "Frame all"

[node name="Canvas" type="Control" parent="Margin/VBox"]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 130)
layout_mode = 2
size_flags_vertical = 3
mouse_filter = 0
